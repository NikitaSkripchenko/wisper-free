# Copy this file to fastlane/.env and fill in local values.
# fastlane/.env is gitignored and should never be committed.

APPLE_ID=your-apple-id@example.com
APPLE_TEAM_ID=TEAMID
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Use the exact identity from: security find-identity -v -p codesigning
DEVELOPER_ID_APPLICATION=Developer ID Application: Your Name (TEAMID)
GITHUB_TOKEN=your-github-token-with-contents-write
# Exported with Sparkle's `generate_keys --account com.wisper.mac -x private-key-file`.
SPARKLE_ED_PRIVATE_KEY=base64-encoded-sparkle-private-key

# Optional. If omitted, Fastlane infers owner/repo from git remote.origin.url.
# GITHUB_REPOSITORY=owner/repo

# Optional. Only needed if you want Fastlane to import a .p12 into a temporary keychain.
# MACOS_CERTIFICATE_BASE64=base64-encoded-p12
# MACOS_CERTIFICATE_PASSWORD=p12-password
# KEYCHAIN_PASSWORD=temporary-keychain-password
