require "base64"
require "fileutils"
require "json"
require "net/http"
require "shellwords"
require "time"
require "uri"
require "open3"

opt_out_usage
default_platform(:mac)

REPO_ROOT = File.expand_path("..", __dir__)
PROJECT = File.join(REPO_ROOT, "Wisper.xcodeproj")
PROJECT_FILE = File.join(PROJECT, "project.pbxproj")
SCHEME = "Wisper"
APP_NAME = "Wisper"
INFO_PLIST = File.join(REPO_ROOT, "Info.plist")
BUILD_DIR = File.join(REPO_ROOT, "build")
EXPORT_PATH = File.join(BUILD_DIR, "export")
DMG_DIR = File.join(BUILD_DIR, "dmg")

def env!(name)
  value = ENV[name].to_s.strip
  UI.user_error!("Missing required environment variable: #{name}") if value.to_s.empty?
  value
end

def write_export_options(path)
  team_id = env!("APPLE_TEAM_ID")

  File.write(path, <<~PLIST)
    <?xml version="1.0" encoding="UTF-8"?>
    <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
    <plist version="1.0">
    <dict>
      <key>method</key>
      <string>developer-id</string>
      <key>signingStyle</key>
      <string>automatic</string>
      <key>teamID</key>
      <string>#{team_id}</string>
    </dict>
    </plist>
  PLIST
end

def release_tag(options)
  tag = options[:tag].to_s
  tag = ENV["GITHUB_REF_NAME"].to_s if tag.empty?
  tag = "v#{app_version}" if tag.empty?
  tag
end

def app_version
  info_plist = File.read(INFO_PLIST)
  match = info_plist.match(%r{<key>CFBundleShortVersionString</key>\s*<string>([^<]+)</string>})
  UI.user_error!("Could not read CFBundleShortVersionString from #{INFO_PLIST}") unless match
  match[1]
end

def app_build_number
  info_plist = File.read(INFO_PLIST)
  match = info_plist.match(%r{<key>CFBundleVersion</key>\s*<string>([^<]+)</string>})
  UI.user_error!("Could not read CFBundleVersion from #{INFO_PLIST}") unless match
  UI.user_error!("CFBundleVersion must be a numeric build number, got #{match[1]}") unless match[1].match?(/\A\d+\z/)
  match[1]
end

def parse_numeric_version(version)
  match = version.match(/\A(\d+)\.(\d+)(?:\.(\d+))?\z/)
  UI.user_error!("Version must be numeric major.minor or major.minor.patch, got #{version}") unless match

  [match[1].to_i, match[2].to_i, match[3].to_s.empty? ? 0 : match[3].to_i]
end

def next_app_version(current_version, bump)
  major, minor, patch = parse_numeric_version(current_version)

  case bump
  when "major"
    "#{major + 1}.0.0"
  when "minor"
    "#{major}.#{minor + 1}.0"
  when "patch"
    "#{major}.#{minor}.#{patch + 1}"
  else
    UI.user_error!("Unsupported version bump #{bump}. Use major, minor, or patch.")
  end
end

def replace_plist_string(content, key, value)
  pattern = %r{(<key>#{Regexp.escape(key)}</key>\s*<string>)([^<]*)(</string>)}
  UI.user_error!("Could not find #{key} in #{INFO_PLIST}") unless content.match?(pattern)

  content.gsub(pattern) { "#{Regexp.last_match(1)}#{value}#{Regexp.last_match(3)}" }
end

def set_app_version!(version, build_number)
  UI.user_error!("Version must be numeric major.minor or major.minor.patch, got #{version}") unless version.match?(/\A\d+\.\d+(?:\.\d+)?\z/)
  UI.user_error!("Build number must be numeric, got #{build_number}") unless build_number.to_s.match?(/\A\d+\z/)

  info_plist = File.read(INFO_PLIST)
  info_plist = replace_plist_string(info_plist, "CFBundleShortVersionString", version)
  info_plist = replace_plist_string(info_plist, "CFBundleVersion", build_number)
  File.write(INFO_PLIST, info_plist)

  project = File.read(PROJECT_FILE)
  UI.user_error!("Could not find MARKETING_VERSION in #{PROJECT_FILE}") unless project.match?(/MARKETING_VERSION = [^;]+;/)
  UI.user_error!("Could not find CURRENT_PROJECT_VERSION in #{PROJECT_FILE}") unless project.match?(/CURRENT_PROJECT_VERSION = [^;]+;/)

  project = project.gsub(/MARKETING_VERSION = [^;]+;/, "MARKETING_VERSION = #{version};")
  project = project.gsub(/CURRENT_PROJECT_VERSION = [^;]+;/, "CURRENT_PROJECT_VERSION = #{build_number};")
  File.write(PROJECT_FILE, project)
end

def safe_filename(value)
  value.gsub(/[^0-9A-Za-z._-]/, "-")
end

def github_repository
  return ENV["GITHUB_REPOSITORY"] unless ENV["GITHUB_REPOSITORY"].to_s.empty?

  remote, = Open3.capture2("git", "-C", REPO_ROOT, "config", "--get", "remote.origin.url")
  match = remote.strip.match(%r{github.com[:/]([^/]+/[^/.]+)(?:\.git)?$})
  UI.user_error!("Missing GITHUB_REPOSITORY and could not infer owner/repo from git remote") unless match
  match[1]
end

def run_git!(*args)
  stdout, stderr, status = Open3.capture3("git", "-C", REPO_ROOT, *args)
  UI.user_error!("git #{args.join(' ')} failed:\n#{stderr}") unless status.success?
  stdout.strip
end

def git_ref_exists?(ref)
  _stdout, _stderr, status = Open3.capture3("git", "-C", REPO_ROOT, "rev-parse", "--verify", "--quiet", ref)
  status.success?
end

def remote_tag_commit(tag_name)
  ref = github_request!("GET", "repos/#{github_repository}/git/ref/tags/#{tag_name}", allowed_statuses: [404])
  return nil unless ref

  object = ref.fetch("object")
  return object.fetch("sha") if object.fetch("type") == "commit"

  if object.fetch("type") == "tag"
    tag = github_request!("GET", "repos/#{github_repository}/git/tags/#{object.fetch("sha")}")
    return tag.fetch("object").fetch("sha")
  end

  UI.user_error!("Remote tag #{tag_name} points to unsupported Git object type #{object.fetch("type")}")
end

def ensure_clean_git_tree!
  status = run_git!("status", "--porcelain", "--untracked-files=no")
  return if status.empty?

  UI.user_error!(<<~ERROR)
    Refusing to create a release from a dirty working tree.
    Commit or stash tracked changes first so the git tag matches the exact source that produced the DMG.
  ERROR
end

def ensure_release_tag!(tag_name)
  head_sha = run_git!("rev-parse", "HEAD")

  if git_ref_exists?("refs/tags/#{tag_name}")
    tag_sha = run_git!("rev-list", "-n", "1", tag_name)
    UI.user_error!("Tag #{tag_name} already exists on #{tag_sha}, not HEAD #{head_sha}.") unless tag_sha == head_sha
    UI.message("Tag #{tag_name} already exists locally at HEAD.")
    return
  end

  run_git!("tag", "-a", tag_name, "-m", "Release #{tag_name}")
  UI.success("Created git tag #{tag_name}.")
end

def push_release_tag!(tag_name)
  local_sha = run_git!("rev-list", "-n", "1", tag_name)
  remote_sha = remote_tag_commit(tag_name)

  if remote_sha
    UI.user_error!("Remote tag #{tag_name} points to #{remote_sha}, not local #{local_sha}.") unless remote_sha == local_sha
    UI.message("Tag #{tag_name} already exists on origin.")
    return
  end

  tag = github_request!(
    "POST",
    "repos/#{github_repository}/git/tags",
    body: {
      tag: tag_name,
      message: "Release #{tag_name}",
      object: local_sha,
      type: "commit",
      tagger: {
        name: run_git!("config", "user.name"),
        email: run_git!("config", "user.email"),
        date: Time.now.utc.iso8601
      }
    }
  )

  github_request!(
    "POST",
    "repos/#{github_repository}/git/refs",
    body: {
      ref: "refs/tags/#{tag_name}",
      sha: tag.fetch("sha")
    }
  )

  UI.success("Published git tag #{tag_name} to GitHub using GITHUB_TOKEN.")
end

def github_api_base_url
  ENV.fetch("GITHUB_API_URL", "https://api.github.com").sub(%r{/*\z}, "")
end

def github_request!(method, path, body: nil, allowed_statuses: [])
  uri = path.start_with?("http") ? URI(path) : URI("#{github_api_base_url}/#{path}")
  request = case method
            when "DELETE" then Net::HTTP::Delete.new(uri)
            when "GET" then Net::HTTP::Get.new(uri)
            when "PATCH" then Net::HTTP::Patch.new(uri)
            when "POST" then Net::HTTP::Post.new(uri)
            else UI.user_error!("Unsupported GitHub HTTP method: #{method}")
            end

  request["Accept"] = "application/vnd.github+json"
  request["Authorization"] = "Bearer #{env!("GITHUB_TOKEN")}"
  request["User-Agent"] = "wisper-fastlane-release"
  request["X-GitHub-Api-Version"] = "2022-11-28"

  if body
    request["Content-Type"] = "application/json"
    request.body = JSON.dump(body)
  end

  response = Net::HTTP.start(uri.host, uri.port, use_ssl: uri.scheme == "https") { |http| http.request(request) }
  status = response.code.to_i
  return nil if allowed_statuses.include?(status)

  if status == 401
    UI.user_error!(<<~ERROR)
      GitHub rejected GITHUB_TOKEN with 401 Bad credentials.

      Create a new GitHub token and put it in fastlane/.env as GITHUB_TOKEN.
      For a fine-grained token, select repository #{github_repository} and grant:
      - Contents: Read and write
      - Metadata: Read-only

      Do not include quotes, spaces, or placeholder text around the token.
    ERROR
  end

  if status == 403
    UI.user_error!(<<~ERROR)
      GitHub accepted GITHUB_TOKEN but denied this request with 403.

      The token likely lacks permission for #{github_repository}. Grant Contents: Read and write, then rerun the lane.
      Response: #{response.body}
    ERROR
  end

  if status == 404 && !allowed_statuses.include?(404)
    UI.user_error!(<<~ERROR)
      GitHub returned 404 for #{github_repository}.

      Either GITHUB_REPOSITORY is wrong, the repo does not exist, or GITHUB_TOKEN does not have access to it.
      Response: #{response.body}
    ERROR
  end

  UI.user_error!("GitHub #{method} #{uri.path} failed with #{status}: #{response.body}") unless status.between?(200, 299)
  return nil if response.body.to_s.empty?

  JSON.parse(response.body)
end

def validate_github_token!
  token = env!("GITHUB_TOKEN")
  UI.user_error!("GITHUB_TOKEN still looks like a placeholder. Put a real GitHub token in fastlane/.env.") if token.include?("your-github-token")

  github_request!("GET", "repos/#{github_repository}")
  UI.success("GitHub token can access #{github_repository}.")
end

def ensure_head_commit_exists_on_github!
  head_sha = run_git!("rev-parse", "HEAD")
  commit = github_request!("GET", "repos/#{github_repository}/commits/#{head_sha}", allowed_statuses: [404])
  return if commit

  UI.user_error!(<<~ERROR)
    HEAD commit #{head_sha} does not exist on GitHub yet.
    Push your branch commit first, then rerun Fastlane. GitHub cannot create a release tag that points to a local-only commit.
  ERROR
end

def github_release_for_tag(tag_name)
  github_request!("GET", "repos/#{github_repository}/releases/tags/#{tag_name}", allowed_statuses: [404])
end

def create_github_release!(tag_name, notes)
  github_request!(
    "POST",
    "repos/#{github_repository}/releases",
    body: {
      tag_name: tag_name,
      target_commitish: run_git!("rev-parse", "HEAD"),
      name: "#{APP_NAME} #{tag_name}",
      body: notes,
      draft: false,
      prerelease: tag_name.include?("-")
    }
  )
end

def delete_existing_release_asset!(release, asset_name)
  assets = github_request!("GET", "repos/#{github_repository}/releases/#{release.fetch("id")}/assets")
  asset = assets.find { |item| item["name"] == asset_name }
  return unless asset

  github_request!("DELETE", "repos/#{github_repository}/releases/assets/#{asset.fetch("id")}")
  UI.message("Deleted existing GitHub Release asset #{asset_name}.")
end

def upload_release_asset!(release, asset_path)
  asset_name = File.basename(asset_path)
  upload_url = release.fetch("upload_url").sub(/\{.*\}\z/, "")
  uri = URI(upload_url)
  uri.query = URI.encode_www_form(name: asset_name)

  request = Net::HTTP::Post.new(uri)
  request["Authorization"] = "Bearer #{env!("GITHUB_TOKEN")}"
  request["Content-Type"] = "application/octet-stream"
  request["User-Agent"] = "wisper-fastlane-release"
  request.body = File.binread(asset_path)

  response = Net::HTTP.start(uri.host, uri.port, use_ssl: uri.scheme == "https") { |http| http.request(request) }
  UI.user_error!("GitHub asset upload failed with #{response.code}: #{response.body}") unless response.code.to_i.between?(200, 299)

  UI.success("Uploaded #{asset_name} to GitHub Release #{release.fetch("html_url")}.")
end

def validate_signing_identity!(identity)
  UI.user_error!("DEVELOPER_ID_APPLICATION still contains the placeholder 'Your Name'. Use the exact identity from `security find-identity -v -p codesigning`.") if identity.include?("Your Name")
  UI.user_error!(<<~ERROR) unless identity.start_with?("Developer ID Application:")
    DEVELOPER_ID_APPLICATION must be a Developer ID Application identity for a public notarized DMG.

    Current value:
    #{identity}

    Apple Development identities can run/debug local apps, but Gatekeeper distribution requires a Developer ID Application certificate from the Apple Developer Program.
  ERROR

  identities, = Open3.capture2("security", "find-identity", "-v", "-p", "codesigning")
  return if identities.include?(%("#{identity}"))

  UI.user_error!(<<~ERROR)
    Could not find this signing identity in your local keychain:
    #{identity}

    Install/export a Developer ID Application certificate in Keychain Access, then set DEVELOPER_ID_APPLICATION to the exact value from:
    security find-identity -v -p codesigning

    Currently available identities:
    #{identities.strip}
  ERROR
end

platform :mac do
  desc "Bump the app marketing version and build number"
  lane :bump_version do |options|
    bump = options[:bump].to_s.strip
    bump = "patch" if bump.empty?

    current_version = app_version
    current_build = app_build_number
    new_version = options[:version].to_s.strip
    new_version = next_app_version(current_version, bump) if new_version.empty?

    new_build = options[:build].to_s.strip
    new_build = (current_build.to_i + 1).to_s if new_build.empty?

    set_app_version!(new_version, new_build)
    UI.success("Bumped #{APP_NAME} from #{current_version} (#{current_build}) to #{new_version} (#{new_build}).")
  end

  desc "Build a signed, notarized DMG and upload it to GitHub Releases"
  lane :release do |options|
    tag_name = release_tag(options)

    ensure_clean_git_tree!
    validate_github_token!
    ensure_head_commit_exists_on_github!
    setup_signing
    app_path = build_signed_app
    verify_app_signature(app_path: app_path)

    dmg_path = package_dmg(app_path: app_path, tag_name: tag_name)
    sign_dmg(dmg_path: dmg_path)
    notarize_dmg(dmg_path: dmg_path)
    verify_dmg(dmg_path: dmg_path)

    ensure_release_tag!(tag_name)
    push_release_tag!(tag_name)

    upload_to_github_release(
      dmg_path: dmg_path,
      tag_name: tag_name,
      release_notes: options[:release_notes]
    )
  end

  desc "Build a signed, notarized DMG without uploading it"
  lane :build_dmg do |options|
    tag_name = release_tag(options)

    setup_signing
    app_path = build_signed_app
    verify_app_signature(app_path: app_path)

    dmg_path = package_dmg(app_path: app_path, tag_name: tag_name)
    sign_dmg(dmg_path: dmg_path)
    notarize_dmg(dmg_path: dmg_path)
    verify_dmg(dmg_path: dmg_path)

    UI.success("Built #{dmg_path}")
  end

  desc "Upload an already-built signed and notarized DMG to GitHub Releases"
  lane :publish_dmg do |options|
    tag_name = release_tag(options)
    dmg_path = options[:dmg_path].to_s.strip
    UI.user_error!("Missing required option: dmg_path") if dmg_path.empty?

    dmg_path = File.expand_path(dmg_path, REPO_ROOT)
    UI.user_error!("DMG does not exist: #{dmg_path}") unless File.exist?(dmg_path)

    ensure_clean_git_tree!
    validate_github_token!
    ensure_head_commit_exists_on_github!
    verify_dmg(dmg_path: dmg_path)

    ensure_release_tag!(tag_name)
    push_release_tag!(tag_name)

    upload_to_github_release(
      dmg_path: dmg_path,
      tag_name: tag_name,
      release_notes: options[:release_notes]
    )
  end

  private_lane :setup_signing do
    next if ENV["MACOS_CERTIFICATE_BASE64"].to_s.empty?

    keychain_name = ENV.fetch("KEYCHAIN_NAME", "wisper-build.keychain")
    keychain_password = env!("KEYCHAIN_PASSWORD")

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    FileUtils.mkdir_p(BUILD_DIR)
    certificate_path = File.join(BUILD_DIR, "developer_id_application.p12")
    File.binwrite(certificate_path, Base64.decode64(env!("MACOS_CERTIFICATE_BASE64")))

    import_certificate(
      certificate_path: certificate_path,
      certificate_password: env!("MACOS_CERTIFICATE_PASSWORD"),
      keychain_name: keychain_name,
      keychain_password: keychain_password,
      log_output: false
    )

    keychain_path = File.expand_path("~/Library/Keychains/#{keychain_name}")
    keychain_path = "#{keychain_path}-db" if !File.exist?(keychain_path) && File.exist?("#{keychain_path}-db")
    keychain_path = keychain_name unless File.exist?(keychain_path)
    sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k #{keychain_password.shellescape} #{keychain_path.shellescape}")
    FileUtils.rm_f(certificate_path)
  end

  private_lane :build_signed_app do
    team_id = env!("APPLE_TEAM_ID")
    identity = env!("DEVELOPER_ID_APPLICATION")
    validate_signing_identity!(identity)

    archive_path = File.join(BUILD_DIR, "#{APP_NAME}.xcarchive")
    export_options_path = File.join(BUILD_DIR, "ExportOptions.plist")

    FileUtils.rm_rf(BUILD_DIR)
    FileUtils.mkdir_p(BUILD_DIR)
    write_export_options(export_options_path)

    sh(
      "xcodebuild archive" \
      " -project #{PROJECT.shellescape}" \
      " -scheme #{SCHEME.shellescape}" \
      " -configuration Release" \
      " -destination #{'generic/platform=macOS'.shellescape}" \
      " -archivePath #{archive_path.shellescape}" \
      " DEVELOPMENT_TEAM=#{team_id.shellescape}" \
      " CODE_SIGN_STYLE=Manual" \
      " CODE_SIGN_IDENTITY=#{identity.shellescape}" \
      " OTHER_CODE_SIGN_FLAGS=#{'--timestamp'.shellescape}"
    )

    sh(
      "xcodebuild -exportArchive" \
      " -archivePath #{archive_path.shellescape}" \
      " -exportPath #{EXPORT_PATH.shellescape}" \
      " -exportOptionsPlist #{export_options_path.shellescape}"
    )

    app_path = Dir[File.join(EXPORT_PATH, "*.app")].first
    UI.user_error!("Export did not produce a .app in #{EXPORT_PATH}") unless app_path
    app_path
  end

  private_lane :verify_app_signature do |options|
    app_path = options[:app_path]

    sh("codesign --verify --deep --strict --verbose=2 #{app_path.shellescape}")
  end

  private_lane :package_dmg do |options|
    app_path = options[:app_path]
    tag_name = options[:tag_name]
    stage_dir = File.join(DMG_DIR, "stage")
    dmg_path = File.join(DMG_DIR, "#{APP_NAME}-#{safe_filename(tag_name)}.dmg")

    FileUtils.rm_rf(DMG_DIR)
    FileUtils.mkdir_p(stage_dir)
    FileUtils.cp_r(app_path, stage_dir)
    FileUtils.ln_s("/Applications", File.join(stage_dir, "Applications"))

    sh(
      "hdiutil create" \
      " -volname #{"#{APP_NAME} #{tag_name}".shellescape}" \
      " -srcfolder #{stage_dir.shellescape}" \
      " -ov" \
      " -format UDZO" \
      " #{dmg_path.shellescape}"
    )

    dmg_path
  end

  private_lane :sign_dmg do |options|
    dmg_path = options[:dmg_path]

    sh(
      "codesign --force" \
      " --sign #{env!("DEVELOPER_ID_APPLICATION").shellescape}" \
      " --timestamp" \
      " #{dmg_path.shellescape}"
    )
  end

  private_lane :notarize_dmg do |options|
    dmg_path = options[:dmg_path]

    sh(
      "xcrun notarytool submit #{dmg_path.shellescape}" \
      " --apple-id #{env!("APPLE_ID").shellescape}" \
      " --password #{env!("APPLE_APP_SPECIFIC_PASSWORD").shellescape}" \
      " --team-id #{env!("APPLE_TEAM_ID").shellescape}" \
      " --wait"
    )
    sh("xcrun stapler staple #{dmg_path.shellescape}")
  end

  private_lane :verify_dmg do |options|
    dmg_path = options[:dmg_path]

    sh("codesign --verify --verbose=2 #{dmg_path.shellescape}")
    sh("spctl -a -vv -t open --context context:primary-signature #{dmg_path.shellescape}")
  end

  private_lane :upload_to_github_release do |options|
    tag_name = options[:tag_name]
    notes = options[:release_notes].to_s
    notes = "Signed and notarized macOS DMG for #{tag_name}." if notes.empty?
    dmg_path = options[:dmg_path]

    release = github_release_for_tag(tag_name)
    release ||= create_github_release!(tag_name, notes)

    delete_existing_release_asset!(release, File.basename(dmg_path))
    upload_release_asset!(release, dmg_path)
  end
end
